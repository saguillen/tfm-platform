{
  "name": "tfm-backstage",
  "version": "0.5.0",
  "private": true,
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "build": "yarn workspace app build && yarn workspace backend build",
    "build:backend": "yarn workspace backend build",
    "build:all": "yarn install --frozen-lockfile && yarn build",
    "tsc": "tsc",
    "tsc:full": "tsc --noEmit",
    "test": "lerna run test -- --passWithNoTests"
  },
  "workspaces": {
    "packages": [
      "packages/app",
      "packages/backend"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "0.25.0",
    "@backstage/core-components": "0.13.10",
    "@backstage/core-plugin-api": "1.8.0",
    "@backstage/dev-utils": "1.0.29",
    "@backstage/test-utils": "1.4.17",
    "@backstage/theme": "0.4.0",
    "@types/node": "18.17.17",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "concurrently": "^8.0.0",
    "lerna": "^7.1.0",
    "typescript": "5.2.2"
  }
}
