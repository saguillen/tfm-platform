{
  "name": "@tfm/backend",
  "version": "1.0.0",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "main": "dist/index.cjs.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "backstage-cli backend:bundle",
    "build-image": "docker image build ../.. -f Dockerfile --tag tfm-backstage",
    "start": "backstage-cli backend:dev",
    "lint": "backstage-cli repo lint --since origin/main",
    "test": "backstage-cli repo test --passWithNoTests",
    "test:coverage": "backstage-cli repo test --coverage --passWithNoTests"
  },
  "dependencies": {
    "@backstage/backend-common": "^0.21.0",
    "@backstage/backend-defaults": "^0.21.0",
    "@backstage/backend-tasks": "^0.5.0",
    "@backstage/catalog-model": "^1.4.0",
    "@backstage/catalog-client": "^1.6.0",
    "@backstage/config": "^1.1.0",
    "@backstage/errors": "^1.2.0",
    "@backstage/plugin-app-backend": "^0.3.46",
    "@backstage/plugin-auth-backend": "^0.20.0",
    "@backstage/plugin-catalog-backend": "^1.19.0",
    "@backstage/plugin-permission-common": "^0.8.0",
    "@backstage/plugin-permission-backend": "^0.5.35",
    "@backstage/plugin-scaffolder-backend": "^1.19.0",
    "@backstage/plugin-search-backend": "^1.5.0",
    "@backstage/plugin-search-backend-module-catalog": "^0.1.0",
    "@backstage/plugin-techdocs-backend": "^1.8.0",
    "express": "^4.18.0",
    "express-promise-router": "^4.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.25.0",
    "@backstage/test-utils": "^1.4.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "typescript": "~5.2.0"
  },
  "engines": {
    "node": "18 || 20"
  }
}
